# ============================================
# DailyCam 프로덕션 환경 변수 템플릿
# ============================================
# 이 파일을 .env.production으로 복사하고 실제 값으로 변경하세요
# cp env.production.template .env.production

# ============================================
# MySQL 데이터베이스 설정
# ============================================
MYSQL_ROOT_PASSWORD=your_strong_root_password_here
MYSQL_PASSWORD=your_strong_database_password_here

# ============================================
# Google Gemini API
# ============================================
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# Google OAuth (로그인 인증)
# ============================================
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ============================================
# JWT Secret Key (강력한 랜덤 문자열 사용)
# ============================================
# 생성 방법: openssl rand -hex 32
JWT_SECRET_KEY=your_very_strong_jwt_secret_key_here

# ============================================
# PortOne 결제 API (포트원)
# ============================================
PORTONE_API_KEY=your_portone_api_key_here
PORTONE_API_SECRET=your_portone_api_secret_here

# ============================================
# YouTube API (콘텐츠 추천 기능)
# ============================================
YOUTUBE_API_KEY=your_youtube_api_key_here

# ============================================
# Tavily API (웹 검색 기능)
# ============================================
TAVILY_API_KEY=your_tavily_api_key_here

# ============================================
# AWS S3 (클립 하이라이트 저장)
# ============================================
# S3 버킷 이름
S3_BUCKET_NAME=your-s3-bucket-name
# AWS 리전 (기본값: ap-northeast-2)
AWS_REGION=ap-northeast-2
# AWS Access Key ID
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
# AWS Secret Access Key
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
# CloudFront 도메인 (선택사항, CDN 사용 시)
# CLOUDFRONT_DOMAIN=d1234567890.cloudfront.net

# ============================================
# 프론트엔드 API Base URL
# ============================================
# 프로덕션 도메인으로 변경하세요
VITE_API_BASE_URL=https://your-domain.com

# ============================================
# CORS 허용 Origin
# ============================================
# 허용할 프론트엔드 도메인을 쉼표로 구분하여 입력
# 예: https://your-domain.com,https://www.your-domain.com
CORS_ALLOWED_ORIGINS=https://your-domain.com

# ============================================
# 백엔드 URL (OAuth 리다이렉트 URI 생성용)
# ============================================
BACKEND_URL=https://your-domain.com
FRONTEND_URL=https://your-domain.com

# ============================================
# VLM 분석 완료 후 로컬 파일 자동 삭제
# ============================================
# True: S3 업로드 후 VLM 분석 완료되면 로컬 파일 삭제 (권장)
# False: 로컬 파일 유지 (디버깅용)
DELETE_VIDEO_AFTER_ANALYSIS=True


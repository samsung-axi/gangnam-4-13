# Hospital Search Backend Environment Configuration
# Copy this file to .env and set your actual values

# OpenAI API Key (Required)
OPENAI_API_KEY=your-openai-api-key-here

# Qdrant Vector Database Configuration
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your-qdrant-api-key-for-cloud

# Server Configuration
HOST=0.0.0.0
PORT=8002

# Logging Configuration
LOG_LEVEL=INFO
DEBUG=false

# Performance Thresholds (BACKEND_PLAN.md specifications)
PERFORMANCE_AVG_THRESHOLD_MS=900
PERFORMANCE_P95_THRESHOLD_MS=1200

# Collection Names
QDRANT_COLLECTION_CHILDREN=derm_children
QDRANT_COLLECTION_PARENTS=derm_parents

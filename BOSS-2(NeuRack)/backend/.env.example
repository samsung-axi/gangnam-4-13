OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_COMPRESS_MODEL=gpt-4o-mini

# Anthropic (optional — planner 만 Claude 로 전환 가능)
# PLANNER_PROVIDER=anthropic 이면 오케스트레이터 planner 가 Claude Sonnet 4.6 사용.
# 비워두거나 openai 로 두면 GPT-4o 사용. 도메인 에이전트/임베딩/이미지는 항상 OpenAI.
ANTHROPIC_API_KEY=
PLANNER_PROVIDER=openai
PLANNER_CLAUDE_MODEL=claude-sonnet-4-6
PLANNER_OPENAI_MODEL=gpt-4o

SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# Celery broker — Upstash Redis TCP endpoint (Connect 탭의 rediss:// URL)
CELERY_BROKER_URL=rediss://default:<password>@xxx.upstash.io:6379/0
CELERY_RESULT_BACKEND=
SCHEDULER_TICK_SECONDS=60

CORS_ORIGINS=["http://localhost:3000"]

# 기업마당 공공 API (https://www.bizinfo.go.kr)
BIZINFO_API_KEY=

# LangSmith (선택) — LangGraph 기반 도메인 에이전트(documents 등) 의 노드·LLM 호출 자동 tracing.
# 설정 시 smith.langchain.com 에 노드별 input/output/latency + chat_completion prompt 전문까지 기록.
# 활성화: LANGCHAIN_TRACING_V2=true + LANGCHAIN_API_KEY=lsv2_pt_... 두 변수 세팅 후 backend 재시작.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=boss2-agents

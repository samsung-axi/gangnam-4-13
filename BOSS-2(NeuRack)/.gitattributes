# Normalize line endings — Windows 개발자 섞여 있어도 LF로 통일
* text=auto eol=lf

# Shell / Python — LF 강제
*.sh      text eol=lf
*.py      text eol=lf
*.toml    text eol=lf

# Windows 전용 스크립트만 CRLF
*.bat     text eol=crlf
*.cmd     text eol=crlf
*.ps1     text eol=crlf

# Markdown / JSON / YAML / SQL
*.md      text eol=lf
*.json    text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.sql     text eol=lf

# TypeScript / JavaScript / CSS
*.ts      text eol=lf
*.tsx     text eol=lf
*.js      text eol=lf
*.jsx     text eol=lf
*.mjs     text eol=lf
*.cjs     text eol=lf
*.css     text eol=lf

# Binary — diff/merge 비활성
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.webp    binary
*.ico     binary
*.svg     text eol=lf
*.woff    binary
*.woff2   binary
*.pdf     binary
*.zip     binary
*.gz      binary
*.tar     binary
*.bin     binary
*.safetensors binary

# Lock files — diff 표시만 축소
package-lock.json  -diff
yarn.lock          -diff
pnpm-lock.yaml     -diff

.env
.env.*
!.env.example
!.env.local.example
*.pem
*.key
*.p12
*.pfx
.secrets/
.vercel

# --- Node / Next.js (frontend/) ---
node_modules/
.next/
out/
dist/
build/
.turbo/
*.tsbuildinfo
next-env.d.ts
.swc/

# --- Python / FastAPI (backend/) ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
.conda/
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
celerybeat-schedule
celerybeat-schedule.*
celerybeat.pid
*.egg-info/
*.egg
.eggs/

# --- ML / HuggingFace cache ---
.cache/
.huggingface/
models_cache/
*.bin
*.safetensors

# --- Docs (internal) ---
docs/superpowers/

# --- Supabase ---
supabase/.branches/
supabase/.temp/

# --- IDE / Editor ---
.vscode/*
!.vscode/settings.json
.idea/
.cursor/
*.swp
*.swo
*~
.claude/
CLAUDE.md

# --- OS ---
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# --- Logs / Runtime ---
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.pid
*.pid.lock
.gstack/

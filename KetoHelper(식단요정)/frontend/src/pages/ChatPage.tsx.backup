import { useState, useRef, useEffect } from 'react'
import { Send, Message, Delete, AccessTime, CalendarToday, Save, Add, Person } from '@mui/icons-material'
import { CircularProgress } from '@mui/material'
import { Button } from '@/components/ui/button'
import { Input } from '@/components/ui/input'
// ScrollAreaëŠ” MUI Boxë¡œ ëŒ€ì²´ ì˜ˆì •
import { useChatStore, ChatMessage, LLMParsedMeal } from '@/store/chatStore'
import { useProfileStore } from '@/store/profileStore'
import { useAuthStore } from '@/store/authStore'
// import { RecipeCard } from '@/components/RecipeCard'
import { PlaceCard } from '@/components/PlaceCard'
import { useSendMessage, useGetChatThreads, useGetChatHistory, ChatThread, ChatHistory } from '@/hooks/useApi'
import { MealParserService, MealService } from '@/lib/mealService'
import { MealData } from '@/data/ketoMeals'
import { format } from 'date-fns'
import KakaoMap from './KakaoMap'

// Message íƒ€ì…ì„ ChatMessageë¡œ ëŒ€ì²´

interface ChatSession {
  id: string
  title: string
  messages: ChatMessage[]
  createdAt: Date
}

export function ChatPage() {
  const [message, setMessage] = useState('')
  const [isLoading, setIsLoading] = useState(false)
  const [chatSessions, setChatSessions] = useState<ChatSession[]>([])
  const [currentSessionId, setCurrentSessionId] = useState<string | null>(null)
  const [currentThreadId, setCurrentThreadId] = useState<string | null>(null) // í˜„ì¬ ìŠ¤ë ˆë“œ ID ì¶”ê°€
  const messagesEndRef = useRef<HTMLDivElement>(null)
  const scrollAreaRef = useRef<HTMLDivElement>(null)
  const [shouldAutoScroll, setShouldAutoScroll] = useState(true)
  const [isSavingMeal, setIsSavingMeal] = useState<string | null>(null) // ì €ì¥ ì¤‘ì¸ ë©”ì‹œì§€ ID
  const [userLocation, setUserLocation] = useState<{ lat: number; lng: number } | null>(null)
  const [selectedPlaceIndexByMsg, setSelectedPlaceIndexByMsg] = useState<Record<string, number | null>>({})

  const { messages, addMessage, clearMessages } = useChatStore()
  // hasStartedChattingì„ ë©”ì‹œì§€ ì¡´ì¬ ì—¬ë¶€ë¡œ ê³„ì‚°
  const hasStartedChatting = messages.length > 0
  const { profile } = useProfileStore()
  const { user, ensureGuestId, isGuest } = useAuthStore()
  const sendMessage = useSendMessage()
  
  // ì±„íŒ… ìŠ¤ë ˆë“œ ê´€ë ¨ í›… ì¶”ê°€
  const { data: chatThreads = [], refetch: refetchThreads } = useGetChatThreads(
    user?.id, 
    isGuest ? ensureGuestId() : undefined
  )
  
  const { data: chatHistory = [], refetch: refetchHistory } = useGetChatHistory(
    currentThreadId || '',
    20
  )

  // ìœ„ì¹˜ ì •ë³´ ê°€ì ¸ì˜¤ê¸°
  useEffect(() => {
    if (navigator.geolocation) {
      navigator.geolocation.getCurrentPosition(
        (position) => {
          setUserLocation({ lat: position.coords.latitude, lng: position.coords.longitude })
        },
        () => {
          setUserLocation({ lat: 37.4979, lng: 127.0276 }) // ê°•ë‚¨ì—­ ê¸°ë³¸ê°’
        }
      )
    } else {
      setUserLocation({ lat: 37.4979, lng: 127.0276 })
    }
  }, [])

  // í˜ì´ì§€ ë¡œë“œ ì‹œ ì´ì „ ëŒ€í™” ë¶ˆëŸ¬ì˜¤ê¸°
  useEffect(() => {
    const loadPreviousChat = async () => {
      try {
        // ìŠ¤ë ˆë“œ ëª©ë¡ì´ ë¡œë“œë˜ë©´ ê°€ì¥ ìµœê·¼ ìŠ¤ë ˆë“œ ì„ íƒ
        if (chatThreads.length > 0 && !currentThreadId) {
          const latestThread = chatThreads[0]
          setCurrentThreadId(latestThread.id)
          setCurrentSessionId(latestThread.id) // í˜¸í™˜ì„±ì„ ìœ„í•´
        }
      } catch (error) {
        console.error('ì´ì „ ëŒ€í™” ë¶ˆëŸ¬ì˜¤ê¸° ì‹¤íŒ¨:', error)
      }
    }

    loadPreviousChat()
  }, [chatThreads, currentThreadId])

  // ì±„íŒ… íˆìŠ¤í† ë¦¬ê°€ ë¡œë“œë˜ë©´ ë©”ì‹œì§€ ìŠ¤í† ì–´ì— ì¶”ê°€
  useEffect(() => {
    if (chatHistory.length > 0) {
      // ê¸°ì¡´ ë©”ì‹œì§€ í´ë¦¬ì–´
      clearMessages()
      
      // íˆìŠ¤í† ë¦¬ ë©”ì‹œì§€ë¥¼ ChatMessage í˜•íƒœë¡œ ë³€í™˜í•˜ì—¬ ì¶”ê°€
      chatHistory.forEach((msg: ChatHistory) => {
        const chatMessage: ChatMessage = {
          id: msg.id.toString(),
          role: msg.role as 'user' | 'assistant',
          content: msg.message,
          timestamp: new Date(msg.created_at)
        }
        addMessage(chatMessage)
      })
    }
  }, [chatHistory, clearMessages, addMessage])

  // ì‹œê°„ í¬ë§·íŒ… í•¨ìˆ˜ë“¤
  const formatMessageTime = (timestamp: Date) => {
    // timestampê°€ Date ê°ì²´ì¸ì§€ í™•ì¸í•˜ê³  ë³€í™˜
    const date = timestamp instanceof Date ? timestamp : new Date(timestamp)
    const now = new Date()
    const diff = now.getTime() - date.getTime()

    // 1ë¶„ ë¯¸ë§Œ
    if (diff < 60000) return 'ë°©ê¸ˆ ì „'

    // 1ì‹œê°„ ë¯¸ë§Œ
    if (diff < 3600000) {
      const minutes = Math.floor(diff / 60000)
      return `${minutes}ë¶„ ì „`
    }

    // 24ì‹œê°„ ë¯¸ë§Œ
    if (diff < 86400000) {
      const hours = Math.floor(diff / 3600000)
      return `${hours}ì‹œê°„ ì „`
    }

    // 7ì¼ ë¯¸ë§Œ
    if (diff < 604800000) {
      const days = Math.floor(diff / 86400000)
      return `${days}ì¼ ì „`
    }

    // ê·¸ ì´ìƒì€ ë‚ ì§œë¡œ í‘œì‹œ
    return date.toLocaleDateString('ko-KR', {
      month: 'short',
      day: 'numeric',
      hour: '2-digit',
      minute: '2-digit'
    })
  }

  const formatDetailedTime = (timestamp: Date) => {
    // timestampê°€ Date ê°ì²´ì¸ì§€ í™•ì¸í•˜ê³  ë³€í™˜
    const date = timestamp instanceof Date ? timestamp : new Date(timestamp)
    return date.toLocaleString('ko-KR', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
      hour: '2-digit',
      minute: '2-digit',
      second: '2-digit'
    })
  }

  const shouldShowTimestamp = (currentIndex: number) => {
    if (currentIndex === 0) return true

    const currentMessage = messages[currentIndex]
    const previousMessage = messages[currentIndex - 1]

    if (!currentMessage || !previousMessage) return true

    // timestampê°€ Date ê°ì²´ì¸ì§€ í™•ì¸í•˜ê³  ë³€í™˜
    const currentTime = currentMessage.timestamp instanceof Date ? currentMessage.timestamp : new Date(currentMessage.timestamp)
    const previousTime = previousMessage.timestamp instanceof Date ? previousMessage.timestamp : new Date(previousMessage.timestamp)

    const timeDiff = currentTime.getTime() - previousTime.getTime()

    // 5ë¶„ ì´ìƒ ì°¨ì´ë‚˜ë©´ íƒ€ì„ìŠ¤íƒ¬í”„ í‘œì‹œ
    return timeDiff > 300000
  }

  const shouldShowDateSeparator = (currentIndex: number) => {
    if (currentIndex === 0) return true

    const currentMessage = messages[currentIndex]
    const previousMessage = messages[currentIndex - 1]

    if (!currentMessage || !previousMessage) return false

    // timestampê°€ Date ê°ì²´ì¸ì§€ í™•ì¸í•˜ê³  ë³€í™˜
    const currentTime = currentMessage.timestamp instanceof Date ? currentMessage.timestamp : new Date(currentMessage.timestamp)
    const previousTime = previousMessage.timestamp instanceof Date ? previousMessage.timestamp : new Date(previousMessage.timestamp)

    const currentDate = currentTime.toDateString()
    const previousDate = previousTime.toDateString()

    return currentDate !== previousDate
  }

  const formatDateSeparator = (timestamp: Date) => {
    // timestampê°€ Date ê°ì²´ì¸ì§€ í™•ì¸í•˜ê³  ë³€í™˜
    const date = timestamp instanceof Date ? timestamp : new Date(timestamp)

    const now = new Date()
    const today = new Date(now.getFullYear(), now.getMonth(), now.getDate())
    const yesterday = new Date(today.getTime() - 86400000)
    const messageDate = new Date(date.getFullYear(), date.getMonth(), date.getDate())

    if (messageDate.getTime() === today.getTime()) {
      return 'ì˜¤ëŠ˜'
    } else if (messageDate.getTime() === yesterday.getTime()) {
      return 'ì–´ì œ'
    } else {
      return date.toLocaleDateString('ko-KR', {
        year: 'numeric',
        month: 'long',
        day: 'numeric'
      })
    }
  }

  const scrollToBottom = () => {
    if (!shouldAutoScroll || !scrollAreaRef.current) return
    const container = scrollAreaRef.current as HTMLDivElement
    container.scrollTo({ top: container.scrollHeight, behavior: 'smooth' })
  }

  const handleScroll = () => {
    const container = scrollAreaRef.current
    if (!container) return

    const { scrollTop, scrollHeight, clientHeight } = container
    const isAtBottom = scrollHeight - scrollTop - clientHeight < 50

    setShouldAutoScroll(isAtBottom)
  }

  useEffect(() => {
    scrollToBottom()
  }, [messages, shouldAutoScroll])

  useEffect(() => {
    const container = scrollAreaRef.current
    if (container) {
      container.addEventListener('scroll', handleScroll)
      return () => container.removeEventListener('scroll', handleScroll)
    }
  }, [hasStartedChatting])

  useEffect(() => {
    // í˜ì´ì§€ ì§„ì… ì‹œ ì±„íŒ… ì»´í¬ë„ŒíŠ¸ ë‚´ë¶€ ìŠ¤í¬ë¡¤ì„ ë¶€ë“œëŸ½ê²Œ ë§¨ ì•„ë˜ë¡œ ì´ë™
    const container = scrollAreaRef.current
    if (container) {
      requestAnimationFrame(() => {
        container.scrollTo({ top: container.scrollHeight, behavior: 'smooth' })
      })
    }
    setShouldAutoScroll(true)
  }, [])

  // ìƒˆ ì±„íŒ… ì„¸ì…˜ ìƒì„±
  const createNewChat = () => {
    const newSessionId = Date.now().toString()
    const newSession: ChatSession = {
      id: newSessionId,
      title: 'ìƒˆ ì±„íŒ…',
      messages: [],
      createdAt: new Date()
    }

    setChatSessions(prev => [newSession, ...prev])
    setCurrentSessionId(newSessionId)
    clearMessages()
    setMessage('')
  }

  // ì±„íŒ… ì„¸ì…˜ ì‚­ì œ
  const deleteChatSession = (sessionId: string) => {
    setChatSessions(prev => prev.filter(session => session.id !== sessionId))
    if (currentSessionId === sessionId) {
      setCurrentSessionId(null)
      clearMessages()
    }
  }

  // ì±„íŒ… ì„¸ì…˜ ì„ íƒ
  const selectChatSession = (sessionId: string) => {
    const session = chatSessions.find(s => s.id === sessionId)
    if (session) {
      setCurrentSessionId(sessionId)
      // ì„ íƒëœ ì„¸ì…˜ì˜ ë©”ì‹œì§€ë“¤ì„ ì±„íŒ… ìŠ¤í† ì–´ì— ë¡œë“œ
      clearMessages()
      session.messages.forEach(msg => addMessage(msg))
    }
  }

  // í˜„ì¬ ì„¸ì…˜ì— ë©”ì‹œì§€ ì¶”ê°€
  const addMessageToCurrentSession = (message: ChatMessage) => {
    if (currentSessionId) {
      setChatSessions(prev => prev.map(session =>
        session.id === currentSessionId
          ? { ...session, messages: [...session.messages, message] }
          : session
      ))
    }
  }

  const handleSendMessage = async () => {
    if (!message.trim() || isLoading) return
    setShouldAutoScroll(true)

    // ì‚¬ìš©ì/ê²ŒìŠ¤íŠ¸ ID ì¤€ë¹„
    const userId = user?.id
    const guestId = isGuest ? ensureGuestId() : undefined

    // í˜„ì¬ ìŠ¤ë ˆë“œê°€ ì—†ìœ¼ë©´ ìƒˆë¡œ ìƒì„± (ë°±ì—”ë“œì—ì„œ ì²˜ë¦¬)
    let threadId = currentThreadId

    const userMessage: ChatMessage = {
      id: Date.now().toString(),
      role: 'user',
      content: message.trim(),
      timestamp: new Date()
    }

    addMessage(userMessage)
    addMessageToCurrentSession(userMessage)
    setMessage('')
    setIsLoading(true)

    try {
      const response = await sendMessage.mutateAsync({
        message: userMessage.content,
        profile: profile ? {
          allergies: profile.allergy_names,
          dislikes: profile.dislike_names,
          goals_kcal: profile.goals_kcal,
          goals_carbs_g: profile.goals_carbs_g
        } : undefined,
        location: undefined, // TODO: ìœ„ì¹˜ ì •ë³´ ì—°ë™
        radius_km: 5,
        thread_id: threadId,
        user_id: userId,
        guest_id: guestId
      })

      // ì‘ë‹µì—ì„œ thread_id ì—…ë°ì´íŠ¸
      if (response.thread_id && response.thread_id !== threadId) {
        setCurrentThreadId(response.thread_id)
        setCurrentSessionId(response.thread_id)
        threadId = response.thread_id
      }

      // ë°±ì—”ë“œ ì‘ë‹µì—ì„œ ì‹ë‹¨ ë°ì´í„° íŒŒì‹±
      let parsedMeal = MealParserService.parseMealFromBackendResponse(response)

      // í…ŒìŠ¤íŠ¸ìš©: ì‹ë‹¨ ì¶”ì²œ ê´€ë ¨ ë©”ì‹œì§€ì¸ ê²½ìš° ì„ì‹œ ë°ì´í„° ìƒì„±
      if (!parsedMeal && (
        userMessage.content.includes('ì‹ë‹¨') ||
        userMessage.content.includes('ì¶”ì²œ') ||
        userMessage.content.includes('ë©”ë‰´') ||
        userMessage.content.includes('ì•„ì¹¨') ||
        userMessage.content.includes('ì ì‹¬') ||
        userMessage.content.includes('ì €ë…')
      )) {
        parsedMeal = {
          breakfast: 'ì•„ë³´ì¹´ë„ í† ìŠ¤íŠ¸ì™€ ìŠ¤í¬ë¨ë¸” ì—ê·¸',
          lunch: 'ê·¸ë¦´ ì¹˜í‚¨ ìƒëŸ¬ë“œ (ì˜¬ë¦¬ë¸Œì˜¤ì¼ ë“œë ˆì‹±)',
          dinner: 'ì—°ì–´ ìŠ¤í…Œì´í¬ì™€ êµ¬ìš´ ë¸Œë¡œì½œë¦¬',
          snack: 'ì•„ëª¬ë“œ í•œ ì¤Œê³¼ ì¹˜ì¦ˆ íë¸Œ'
        }
      }

      const assistantMessage: ChatMessage = {
        id: (Date.now() + 1).toString(),
        role: 'assistant',
        content: response.response,
        results: response.results,
        timestamp: new Date(),
        mealData: parsedMeal // íŒŒì‹±ëœ ì‹ë‹¨ ë°ì´í„° ì¶”ê°€
      }

      addMessage(assistantMessage)
      addMessageToCurrentSession(assistantMessage)

      // ì²« ë²ˆì§¸ ë©”ì‹œì§€ì¸ ê²½ìš° ì„¸ì…˜ ì œëª© ì—…ë°ì´íŠ¸ (ì‚¬ìš©ì ë©”ì‹œì§€ê°€ ì²« ë²ˆì§¸ ë©”ì‹œì§€ì¸ì§€ í™•ì¸)
      if (sessionId) {
        setChatSessions(prev => prev.map(session => {
          if (session.id === sessionId && session.title === 'ìƒˆ ì±„íŒ…') {
            return { ...session, title: userMessage.content.slice(0, 30) + (userMessage.content.length > 30 ? '...' : '') }
          }
          return session
        }))
      }
    } catch (error) {
      console.error('ë©”ì‹œì§€ ì „ì†¡ ì‹¤íŒ¨:', error)
      const errorMessage: ChatMessage = {
        id: (Date.now() + 1).toString(),
        role: 'assistant',
        content: 'ì£„ì†¡í•©ë‹ˆë‹¤. ë©”ì‹œì§€ ì²˜ë¦¬ ì¤‘ ì˜¤ë¥˜ê°€ ë°œìƒí–ˆìŠµë‹ˆë‹¤. ë‹¤ì‹œ ì‹œë„í•´ì£¼ì„¸ìš”.',
        timestamp: new Date()
      }
      addMessage(errorMessage)
      addMessageToCurrentSession(errorMessage)
    } finally {
      setIsLoading(false)
    }
  }

  const handleKeyDown = (e: React.KeyboardEvent) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault()
      handleSendMessage()
    }
  }

  // ì‹ë‹¨ ìº˜ë¦°ë”ì— ì €ì¥
  const handleSaveMealToCalendar = async (messageId: string, mealData: LLMParsedMeal, targetDate?: string) => {
    if (!user?.id) {
      const errorMessage: ChatMessage = {
        id: Date.now().toString(),
        role: 'assistant',
        content: 'âŒ ì‹ë‹¨ ì €ì¥ì„ ìœ„í•´ ë¡œê·¸ì¸ì´ í•„ìš”í•©ë‹ˆë‹¤.',
        timestamp: new Date()
      }
      addMessage(errorMessage)
      addMessageToCurrentSession(errorMessage)
      return
    }

    setIsSavingMeal(messageId)

    try {
      const dateToSave = targetDate || format(new Date(), 'yyyy-MM-dd')

      const mealToSave: MealData = {
        breakfast: mealData.breakfast || '',
        lunch: mealData.lunch || '',
        dinner: mealData.dinner || '',
        snack: mealData.snack || ''
      }

      const success = await MealService.saveMeal(dateToSave, mealToSave, user.id)

      if (success) {
        // ì„±ê³µ ë©”ì‹œì§€ ì¶”ê°€
        const successMessage: ChatMessage = {
          id: Date.now().toString(),
          role: 'assistant',
          content: `âœ… ì‹ë‹¨ì´ ${format(new Date(dateToSave), 'Mì›” dì¼')} ìº˜ë¦°ë”ì— ì €ì¥ë˜ì—ˆìŠµë‹ˆë‹¤! ìº˜ë¦°ë” í˜ì´ì§€ì—ì„œ í™•ì¸í•´ë³´ì„¸ìš”.`,
          timestamp: new Date()
        }

        addMessage(successMessage)
        addMessageToCurrentSession(successMessage)
      } else {
        throw new Error('ì €ì¥ ì‹¤íŒ¨')
      }
    } catch (error) {
      console.error('ì‹ë‹¨ ì €ì¥ ì‹¤íŒ¨:', error)

      // ì‹¤íŒ¨ ë©”ì‹œì§€ ì¶”ê°€
      const errorMessage: ChatMessage = {
        id: Date.now().toString(),
        role: 'assistant',
        content: 'âŒ ì‹ë‹¨ ì €ì¥ì— ì‹¤íŒ¨í–ˆìŠµë‹ˆë‹¤. ë‹¤ì‹œ ì‹œë„í•´ì£¼ì„¸ìš”.',
        timestamp: new Date()
      }

      addMessage(errorMessage)
      addMessageToCurrentSession(errorMessage)
    } finally {
      setIsSavingMeal(null)
    }
  }

  // ë¹ ë¥¸ ì§ˆë¬¸ ë©”ì‹œì§€ ì „ì†¡
  const handleQuickMessage = async (quickMessage: string) => {
    if (!quickMessage.trim() || isLoading) return
    setShouldAutoScroll(true)

    // í˜„ì¬ ì„¸ì…˜ì´ ì—†ìœ¼ë©´ ìƒˆ ì„¸ì…˜ ìƒì„±
    let sessionId = currentSessionId
    if (!sessionId) {
      const newSessionId = Date.now().toString()
      const newSession: ChatSession = {
        id: newSessionId,
        title: 'ìƒˆ ì±„íŒ…',
        messages: [],
        createdAt: new Date()
      }

      setChatSessions(prev => [newSession, ...prev])
      setCurrentSessionId(newSessionId)
      sessionId = newSessionId
    }

    const userMessage: ChatMessage = {
      id: Date.now().toString(),
      role: 'user',
      content: quickMessage.trim(),
      timestamp: new Date()
    }

    addMessage(userMessage)
    addMessageToCurrentSession(userMessage)
    setIsLoading(true)

    try {
      const response = await sendMessage.mutateAsync({
        message: userMessage.content,
        profile: profile ? {
          allergies: profile.allergy_names,
          dislikes: profile.dislike_names,
          goals_kcal: profile.goals_kcal,
          goals_carbs_g: profile.goals_carbs_g
        } : undefined,
        location: undefined, // TODO: ìœ„ì¹˜ ì •ë³´ ì—°ë™
        radius_km: 5
      })

      // ë°±ì—”ë“œ ì‘ë‹µì—ì„œ ì‹ë‹¨ ë°ì´í„° íŒŒì‹±
      let parsedMeal = MealParserService.parseMealFromBackendResponse(response)

      // í…ŒìŠ¤íŠ¸ìš©: ì‹ë‹¨ ì¶”ì²œ ê´€ë ¨ ë©”ì‹œì§€ì¸ ê²½ìš° ì„ì‹œ ë°ì´í„° ìƒì„±
      if (!parsedMeal && (
        userMessage.content.includes('ì‹ë‹¨') ||
        userMessage.content.includes('ì¶”ì²œ') ||
        userMessage.content.includes('ë©”ë‰´') ||
        userMessage.content.includes('ì•„ì¹¨') ||
        userMessage.content.includes('ì ì‹¬') ||
        userMessage.content.includes('ì €ë…')
      )) {
        parsedMeal = {
          breakfast: 'ì•„ë³´ì¹´ë„ í† ìŠ¤íŠ¸ì™€ ìŠ¤í¬ë¨ë¸” ì—ê·¸',
          lunch: 'ê·¸ë¦´ ì¹˜í‚¨ ìƒëŸ¬ë“œ (ì˜¬ë¦¬ë¸Œì˜¤ì¼ ë“œë ˆì‹±)',
          dinner: 'ì—°ì–´ ìŠ¤í…Œì´í¬ì™€ êµ¬ìš´ ë¸Œë¡œì½œë¦¬',
          snack: 'ì•„ëª¬ë“œ í•œ ì¤Œê³¼ ì¹˜ì¦ˆ íë¸Œ'
        }
      }

      const assistantMessage: ChatMessage = {
        id: (Date.now() + 1).toString(),
        role: 'assistant',
        content: response.response,
        results: response.results,
        timestamp: new Date(),
        mealData: parsedMeal // íŒŒì‹±ëœ ì‹ë‹¨ ë°ì´í„° ì¶”ê°€
      }

      addMessage(assistantMessage)
      addMessageToCurrentSession(assistantMessage)

      // ì²« ë²ˆì§¸ ë©”ì‹œì§€ì¸ ê²½ìš° ì„¸ì…˜ ì œëª© ì—…ë°ì´íŠ¸ (ì‚¬ìš©ì ë©”ì‹œì§€ê°€ ì²« ë²ˆì§¸ ë©”ì‹œì§€ì¸ì§€ í™•ì¸)
      if (sessionId) {
        setChatSessions(prev => prev.map(session => {
          if (session.id === sessionId && session.title === 'ìƒˆ ì±„íŒ…') {
            return { ...session, title: userMessage.content.slice(0, 30) + (userMessage.content.length > 30 ? '...' : '') }
          }
          return session
        }))
      }
    } catch (error) {
      console.error('ë©”ì‹œì§€ ì „ì†¡ ì‹¤íŒ¨:', error)
      const errorMessage: ChatMessage = {
        id: (Date.now() + 1).toString(),
        role: 'assistant',
        content: 'ì£„ì†¡í•©ë‹ˆë‹¤. ë©”ì‹œì§€ ì²˜ë¦¬ ì¤‘ ì˜¤ë¥˜ê°€ ë°œìƒí–ˆìŠµë‹ˆë‹¤. ë‹¤ì‹œ ì‹œë„í•´ì£¼ì„¸ìš”.',
        timestamp: new Date()
      }
      addMessage(errorMessage)
      addMessageToCurrentSession(errorMessage)
    } finally {
      setIsLoading(false)
    }
  }

  return (

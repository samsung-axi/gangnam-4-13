offline/datasets/**/*.csv
offline/datasets/vfinal/
# 예시/샘플만 허용하고 싶으면 아래 라인으로 예외 허용(필요시 주석 해제)
# !offline/datasets/kaggle_efd/example_*.jsonl

# registry artifacts (학습 산출물)
offline/registry/models/
offline/registry/scalers/
# 안전망: 산출물 확장자(이미 전역에서도 무시 중이지만 중복 명시)
offline/registry/**/*.[pP][tT]
offline/registry/**/*.[pP][kK][lL]
offline/registry/**/*.[oO][nN][nN][xX]
offline/registry/**/*.[hH]5

# logs / temps

{
    "name": "ai-5-main-project-root",
    "version": "1.0.0",
    "description": "Root project to manage multi-service startup",
    "scripts": {
        "dev": "npm run dev:front",
        "dev:front": "cd frontend && npx expo start -c --port 3000",
        "dev:back": "export $(grep -v '^#' .env | xargs) && cd backend && ./gradlew clean build bootRun",
        "dev:ai": "ai_env/bin/python -m uvicorn app.main:app --app-dir ai --host 0.0.0.0 --port 8001 --reload"
    },
    "proxy": "http://localhost:3000",
    "keywords": [],

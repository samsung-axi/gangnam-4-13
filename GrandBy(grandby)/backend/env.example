# Grandby Backend - Environment Variables Example
# 이 파일을 복사해서 .env 파일을 만들고 실제 값으로 변경하세요
# cp env.example .env

# ==================== Database ====================
DATABASE_URL=postgresql://grandby:grandby_secret_password@db:5432/grandby_db
DB_ECHO=false

# ==================== Redis ====================
REDIS_URL=redis://redis:6379/0

# ==================== JWT Authentication ====================
# openssl rand -hex 32 로 생성
SECRET_KEY=your-super-secret-jwt-key-change-in-production-min-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== OpenAI API ====================
# https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova

# ==================== Cartesia TTS API ====================
# https://cartesia.ai 에서 발급
CARTESIA_API_KEY=sk_car_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CARTESIA_TTS_MODEL=sonic-2
CARTESIA_TTS_VOICE=304fdbd8-65e6-40d6-ab78-f9d18b9efdf9
CARTESIA_ACCESS_TOKEN_EXPIRES_IN=60

# ==================== Naver Clova TTS API ====================
# https://www.ncloud.com/ 에서 발급
NAVER_CLOVA_CLIENT_ID=your-client-id
NAVER_CLOVA_CLIENT_SECRET=your-client-secret
NAVER_CLOVA_TTS_SPEAKER=mijin
NAVER_CLOVA_TTS_SPEED=0
NAVER_CLOVA_TTS_PITCH=0
NAVER_CLOVA_TTS_VOLUME=0

# ==================== Twilio (전화 통화) ====================
# https://www.twilio.com/console 에서 확인
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+821012345678
# WebSocket용 공개 도메인 (ngrok 또는 실제 도메인)
# 예: your-domain.com 또는 abc123.ngrok.io
API_BASE_URL=your-domain.com
# 테스트용 전화번호 (전화를 받을 본인의 번호)
TEST_PHONE_NUMBER=+821012345678

# ==================== AWS S3 (음성 파일 저장) ====================
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=ap-northeast-2
S3_BUCKET_NAME=grandby-audio-files

# ==================== App Settings ====================
ENVIRONMENT=development
DEBUG=true
APP_NAME=Grandby
APP_VERSION=1.0.0

# ==================== CORS ====================
# Expo 개발 서버 URL (콤마로 구분)
CORS_ORIGINS=http://localhost:19000,http://localhost:19006,exp://localhost:19000

# ==================== Logging ====================
LOG_LEVEL=INFO

# ==================== Sentry (에러 트래킹) ====================
SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# ==================== Celery (비동기 작업) ====================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ==================== RTZR STT (Korean Speech Recognition) ====================
# https://developers.rtzr.ai 에서 발급
RTZR_CLIENT_ID=your-client-id
RTZR_CLIENT_SECRET=your-secret

# ==================== Speech-to-Text Provider ====================
# STT 제공자 선택: "rtzr", "google", "openai"
STT_PROVIDER=rtzr

# ==================== AI Call Settings ====================
# 기본 통화 시간 (24시간 형식)
DEFAULT_CALL_TIME=20:00
# 통화 최대 시간 (분)
MAX_CALL_DURATION=10
# LLM 프롬프트 최대 토큰
MAX_PROMPT_TOKENS=4000

# ==================== Feature Flags ====================
ENABLE_AUTO_DIARY=true
ENABLE_TODO_EXTRACTION=true
ENABLE_EMOTION_ANALYSIS=true
ENABLE_NOTIFICATIONS=true

